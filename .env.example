DATABASE_URL=postgresql://user:password@host/database?sslmode=require
JWT_SECRET=replace-with-at-least-32-random-characters
JWT_EXPIRES_IN=8h
# Backend redirect target after SSO; in production this must be the Vercel frontend URL, not localhost.
CLIENT_URL=http://localhost:3000
NEXT_PUBLIC_API_URL=http://localhost:5000
BOOTSTRAP_ADMIN_KEY=replace-once-before-first-admin-registration

# Master Dashboard SSO. Change SSO_SECRET when rotating the shared secret.
SSO_SECRET=fjgroup-master-sso-shared-secret-2026-change-later
# Signed master user expected from the Master Dashboard token.
SSO_MASTER_USER=chmfj@live.com
# Signed master role expected from the Master Dashboard token.
SSO_MASTER_ROLE=ceo
# Change SSO_APP_NAME only if the Master Dashboard sends a different exact app value.
SSO_APP_NAME=Pulse CRM
# Change SSO_LOCAL_CEO_USERNAME to the local CEO/admin account email in this app.
SSO_LOCAL_CEO_USERNAME=chmfj@live.com
# Change SSO_REDIRECT_PATH to the CEO/admin landing page.
SSO_REDIRECT_PATH=/dashboard
